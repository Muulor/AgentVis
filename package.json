{
  "name": "agentvis",
  "version": "0.3.2",
  "description": "AgentVis - Visual Agent Workspace",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:broker-helper": "cargo build --bin agentvis-broker-fetch --bin agentvis_wfp_helper --manifest-path src-tauri/Cargo.toml && node scripts/prepare-broker-helper-resource.mjs debug",
    "dev:sync-skills": "node scripts/sync-tauri-dev-resources.mjs",
    "dev:tauri": "npm run dev:broker-helper && npm run dev:sync-skills && npm run dev",
    "build:python-runtime": "powershell -ExecutionPolicy Bypass -File scripts/build-python-runtime-v1.ps1",
    "build": "tsc && vite build",
    "build:broker-helper": "cargo build --release --bin agentvis-broker-fetch --bin agentvis_wfp_helper --manifest-path src-tauri/Cargo.toml && node scripts/prepare-broker-helper-resource.mjs release",
    "check:rust-boundaries": "powershell -ExecutionPolicy Bypass -File scripts/check-rust-panic-boundaries.ps1",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "1.59.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "browser-image-compression": "^2.0.2",
    "echarts": "^6.0.0",
    "heic2any": "^0.0.4",
    "lucide-react": "^0.562.0",
    "mermaid": "^11.15.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tslog": "^4.10.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.2.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.0.9",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.1",
    "lint-staged": "^17.0.5",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vite": "^6.4.2",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "@larksuiteoapi/node-sdk": {
      "axios": "^1.16.1"
    }
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": "eslint --fix --quiet",
    "{vite,vitest}.config.ts": "eslint --fix --quiet"
  }
}
