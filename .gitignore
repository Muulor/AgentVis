# ========================================
# AgentVis .gitignore
# ========================================

# ========================================
# Node.js / npm
# ========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ========================================
# Tauri / Rust
# ========================================
src-tauri/target/
src-tauri/broker-bin/agentvis-broker-fetch*
src-tauri/python-runtime/python-runtime-v1.zip
src-tauri/python-runtime/python-runtime-v1.signature
*.rs.bk

# ========================================
# Python
# ========================================
model-server/dist/
model-server/build/
model-server/*.spec
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
*.egg
.venv/
venv/
ENV/
env/

# ========================================
# Build outputs
# ========================================
dist/
dist-ssr/
*.local
*.tsbuildinfo

# ========================================
# Build outputs
# ========================================
website/
website/assets/
*.exe

# ========================================
# IDE / Editor
# ========================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# ========================================
# OS Files
# ========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ========================================
# Environment / Secrets
# ========================================
.env
.env.local
.env.*.local
*.pem
*.key

# ========================================
# Logs
# ========================================
logs/
*.log

# ========================================
# Testing
# ========================================
coverage/
.nyc_output/
.pytest_cache/

# ========================================
# Misc
# ========================================
*.bak
*.tmp
*.temp
.cache/
.agentvis-build/

# ========================================
# AI Models (GGUF, etc.)
# ========================================
models/
*.gguf
