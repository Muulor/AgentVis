# Normalize text files in the repository while preserving binary assets.
* text=auto

# Keep source and documentation line endings deterministic across platforms.
*.cjs text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.mjs text eol=lf
*.py text eol=lf
*.rs text eol=lf
*.toml text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Root configuration files without a conventional extension also stay on LF.
.editorconfig text eol=lf
.git-blame-ignore-revs text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf
.prettierrc text eol=lf

*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

*.ico binary
*.icns binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.avif binary
*.mp4 binary
*.mov binary
*.zip binary
*.db binary
