# Normalize text files in the repository while preserving binary assets.
* text=auto

*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

*.ico binary
*.icns binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.avif binary
*.mp4 binary
*.mov binary
*.zip binary
*.db binary
